# Hardwareless AI — Environment Configuration
# Copy this file to .env and adjust values for your deployment

# ============================================================================
# Backend Gateway
# ============================================================================
ENVIRONMENT=production          # development | staging | production
DEV_MODE=0                     # 1 to enable dev toolbar, 0 otherwise
SECURITY_HEADERS_ENABLED=1     # Enable CSP, HSTS, etc.
ENABLE_FINGERPRINTING=1        # Enable bot fingerprinting
ENABLE_REQUEST_SIGNING=0       # Enable HMAC request signing (requires secret)
REQUEST_SIGNING_SECRET=        # HMAC secret (generate with: openssl rand -hex 32)
ENABLE_GRAPHQL=0               # Enable /v1/graphql endpoint
ENABLE_GRPC=0                  # Enable gRPC server

# CORS — comma-separated origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis connection
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Optional: Secrets Backends
# ============================================================================
# HashiCorp Vault
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=xxxxxxxxxxxxxxxx

# AWS Secrets Manager
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxx

# ============================================================================
# Frontend (Next.js) — prefix with NEXT_PUBLIC_
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_REFRESH_INTERVAL=2000
NEXT_PUBLIC_ENABLE_STREAMING=1
NEXT_PUBLIC_ENABLE_BATCH=1
NEXT_PUBLIC_ENABLE_GRAPHQL=0

# ============================================================================
# Node.js runtime
# ============================================================================
NODE_ENV=production
